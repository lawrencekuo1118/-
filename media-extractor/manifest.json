{
  "manifest_version": 3,
  "name": "Page Media Extractor",
  "version": "1.0.0",
  "description": "Find and download images and videos from the current page without opening new tabs.",
  "permissions": [
    "activeTab",
    "downloads",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scan page media"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "extractor.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
